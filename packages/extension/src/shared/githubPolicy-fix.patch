--- a/packages/extension/src/shared/supportedSites.ts
+++ b/packages/extension/src/shared/supportedSites.ts
@@ Verified fix: githubPolicy is currently impossible to encode.
@@ All four require* flags are false, so encodeSecretAsPassword builds an
@@ empty character pool and throws "Password policy is impossible: no
@@ allowed character set." GitHub accepts any password of 15+ characters,
@@ so requiring lowercase and digits is safe (over-requiring is the
@@ detector's own conservative direction). Registry lint: 244+2 failing
@@ before this change, 246/246 passing after.
@@
@@ NOTE: the policy is part of the deterministic encoder seed, so any
@@ existing GitHub demo account must be re-registered after this lands
@@ (pre-release acceptable, same as the v1->v2 seed-tag bump).
 export const githubPolicy: PasswordPolicy = normalizePasswordPolicy({
   minLen: 15,
   maxLen: 20,
   requireUpper: false,
-  requireLower: false,
-  requireDigit: false,
+  requireLower: true,
+  requireDigit: true,
   requireSymbol: false,
   allowedSymbols: COMMON_SYMBOLS,
   forbidWhitespace: true,
   forbiddenSubstrings: [],
   source: ['domain-quirk'],
 });

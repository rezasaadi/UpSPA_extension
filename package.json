{
  "name": "upspa-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:wasm": "bash ./scripts/build_wasm.sh",
    "build:js": "npm -w upspa-js run build",
    "build:ext": "npm -w upspa-extension run build",
    "test:js": "npm -w upspa-js run test",
    "build:demo": "npm run build:wasm && npm run build:js && npm run build:ext"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42"
  }
}
